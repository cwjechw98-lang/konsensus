SENTRY_AUTH_TOKEN=

# Telegram Bot — создать через @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
# Один и тот же секрет используется для Vercel Cron:
# - /api/telegram/editorial/run
# - /api/keepalive/supabase
CRON_SECRET=
TELEGRAM_BOT_USERNAME=KonsensusAppBot
TELEGRAM_RELEASE_CHANNEL_ID=
NEXT_PUBLIC_TELEGRAM_RELEASE_CHANNEL_URL=
KONSENSUS_ADMIN_EMAILS=admin1@example.com,admin2@example.com
KONSENSUS_GITHUB_REPO=cwjechw98-lang/konsensus
